<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.v.log" >

    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application>
        <provider
            android:name=".inspector.VLogFileProvider"
            android:authorities="${applicationId}.vlog.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/vlog_file_paths" />
        </provider>
        <activity
            android:name=".inspector.LocalLogFilesActivity"
            android:exported="false"
            android:label="@string/vlog_local_files_title"
            android:launchMode="singleTask"
            android:taskAffinity="${applicationId}.vlog.inspector"
            android:theme="@style/VLogInspectorTheme" />
        <activity
            android:name=".inspector.LogViewerActivity"
            android:exported="false"
            android:label="@string/vlog_viewer_title"
            android:launchMode="singleTask"
            android:taskAffinity="${applicationId}.vlog.inspector"
            android:theme="@style/VLogInspectorTheme" />
        <activity
            android:name=".inspector.LogDetailActivity"
            android:exported="false"
            android:label="@string/vlog_detail_title"
            android:launchMode="singleTask"
            android:taskAffinity="${applicationId}.vlog.inspector"
            android:theme="@style/VLogInspectorTheme" />
    </application>
</manifest>
